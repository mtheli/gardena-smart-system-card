{
  "name": "gardena_smart_system_card",
  "version": "0.10.0",
  "description": "Custom Lovelace card for the Gardena Smart System integration",
  "source": "src/index.js",
  "module": "dist/gardena_smart_system_card.js",
  "targets": {
    "module": {
      "includeNodeModules": true
    }
  },
  "scripts": {
    "watch": "node scripts/gen_build_info.mjs && parcel watch",
    "build": "node scripts/gen_build_info.mjs && parcel build src/index.js --dist-dir dist --no-source-maps",
    "check:translations": "node scripts/check-translations.js"
  },
  "devDependencies": {
    "@parcel/transformer-inline-string": "^2.15.2",
    "parcel": "^2.15.2"
  },
  "dependencies": {
    "lit": "^3.3.1"
  },
  "license": "MIT"
}
